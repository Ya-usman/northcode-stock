# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# App URL (required for payment callbacks + receipts)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Paystack (Nigeria — NGN) ─────────────────────────────────────────────────
# https://dashboard.paystack.com/#/settings/developer
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Flutterwave (pays FCFA: CI, SN, ML, BJ, TG, NE) ────────────────────────
# https://dashboard.flutterwave.com/dashboard/settings/apis
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X

# ── Wave (Sénégal, Côte d'Ivoire, Mali — XOF) ───────────────────────────────
# https://developer.wave.com → Business API keys
WAVE_API_KEY=wave_sn_prod_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── NotchPay (Cameroun — XAF) ───────────────────────────────────────────────
# https://business.notchpay.co/settings/developer
NOTCHPAY_PUBLIC_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend (email notifications) ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=alerts@your-domain.com

# ── WhatsApp (numéro du propriétaire en format international) ────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=2216000000000

# ── Push notifications (VAPID) ───────────────────────────────────────────────
# Générer avec: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:your@email.com

# ── Super Admin ──────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAILS=admin@your-domain.com
